generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  nome           String
  email          String    @unique
  emailVerified  Boolean   @default(false) @map("email_verified")
  slug           String    @unique
  dataNascimento DateTime? @map("data_nascimento")
  idProfessor    String?   @map("id_professor")
  resetPassword  Boolean   @default(false) @map("reset_password")
  avatarUrl      String?   @map("avatar_url")
  role           Role      @default(ALUNO)
  alunoDesde     DateTime  @default(now()) @map("aluno_desde")
  telefone       String?
  carreiraValue  String?   @map("carreira_value")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  professor User?           @relation("ProfessorAluno", fields: [idProfessor], references: [id])
  alunos    User[]          @relation("ProfessorAluno")
  carreira  DomainCarreira? @relation(fields: [carreiraValue], references: [value])
  accounts  Account[]
  sessions  Session[]
  respostas Resposta[]

  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

enum Role {
  PROFESSOR
  ALUNO
  EXALUNO
}

model Prova {
  id          String   @id @default(uuid())
  ano         String
  notaMinima  Int      @map("nota_minima")
  notaMaxima  Int      @map("nota_maxima")
  peso1       Int      @map("peso_1")
  peso2       Int      @map("peso_2")
  peso3       Int      @map("peso_3")
  peso4       Int      @map("peso_4")
  statusProva Boolean  @default(false) @map("status_prova")
  dataCriacao DateTime @default(now()) @map("data_criacao")

  questoes Questao[]

  @@map("provas")
}

model Questao {
  id              String  @id @default(uuid())
  numero          Int
  gabarito        String
  dificuldade     Int
  habilidadeValue Int     @map("habilidade_value")
  assuntoValue    String  @map("assunto_value")
  idProva         String? @map("id_prova")

  prova      Prova?         @relation(fields: [idProva], references: [id])
  habilidade Habilidade     @relation(fields: [habilidadeValue], references: [value])
  assunto    DomainAssuntos @relation(fields: [assuntoValue], references: [value])
  respostas  Resposta[]

  @@map("questoes")
}

model Habilidade {
  value     Int    @id
  descricao String

  questaos Questao[]

  @@map("@habilidades")
}

model Resposta {
  idAluno   String  @map("id_aluno")
  idQuestao String  @map("id_questao")
  resposta  String
  resultado Boolean

  aluno   User    @relation(fields: [idAluno], references: [id])
  questao Questao @relation(fields: [idQuestao], references: [id])

  @@id([idAluno, idQuestao])
  @@map("respostas")
}

model DomainCarreira {
  value String @id
  label String @unique

  alunos User[]

  @@map("@carreiras")
}

model DomainAssuntos {
  value    String    @id
  label    String
  questaos Questao[]

  @@map("@assuntos")
}

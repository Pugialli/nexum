generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  nome          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  slug          String   @unique
  resetPassword Boolean  @default(false) @map("reset_password")
  avatarUrl     String?  @map("avatar_url")
  role          Role     @default(ALUNO)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accounts   Account[]
  sessions   Session[]
  alunos     Aluno[]
  professors Professor[]

  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

enum Role {
  PROFESSOR
  ALUNO
  EXALUNO
}

model Aluno {
  idUser         String    @id @map("id_user")
  dataNascimento DateTime? @map("data_nascimento")
  idProfessor    String    @map("id_professor")
  telefone       String?
  carreiraValue  String?   @map("carreira_value")

  user        User            @relation(fields: [idUser], references: [id], onDelete: Cascade)
  professor   Professor       @relation("ProfessorAluno", fields: [idProfessor], references: [idUser])
  carreira    DomainCarreira? @relation(fields: [carreiraValue], references: [value])
  provaAlunos ProvaAluno[]

  @@map("alunos")
}

model Professor {
  idUser   String  @id @map("id_user")
  formacao String?
  telefone String?

  user   User    @relation(fields: [idUser], references: [id], onDelete: Cascade)
  alunos Aluno[] @relation("ProfessorAluno")

  @@map("professores")
}

model Prova {
  id          String   @id @default(uuid())
  ano         String
  notaMinima  Int      @map("nota_minima")
  notaMaxima  Int      @map("nota_maxima")
  peso1       Int      @default(1) @map("peso_1")
  peso2       Int      @default(1) @map("peso_2")
  peso3       Int      @default(1) @map("peso_3")
  peso4       Int      @default(1) @map("peso_4")
  peso5       Int      @default(1) @map("peso_5")
  statusProva Boolean  @default(false) @map("status_prova")
  dataCriacao DateTime @default(now()) @map("data_criacao")

  questoes    Questao[]
  provaAlunos ProvaAluno[]

  @@map("provas")
}

model Questao {
  id              String  @id @default(uuid())
  numero          Int
  gabarito        String
  dificuldade     Int
  habilidadeValue Int     @map("habilidade_value")
  assuntoValue    String  @map("assunto_value")
  idProva         String? @map("id_prova")

  prova      Prova?           @relation(fields: [idProva], references: [id])
  habilidade DomainHabilidade @relation(fields: [habilidadeValue], references: [value])
  assunto    DomainAssuntos   @relation(fields: [assuntoValue], references: [value])
  respostas  Resposta[]

  @@map("questoes")
}

model ProvaAluno {
  id        String   @id @default(uuid()) @map("id_prova_aluno")
  idAluno   String   @map("id_aluno")
  idProva   String   @map("id_prova")
  createdAt DateTime @default(now()) @map("created_at")
  gcp       Int

  prova     Prova      @relation(fields: [idProva], references: [id])
  aluno     Aluno      @relation(fields: [idAluno], references: [idUser])
  respostas Resposta[]

  @@unique([idAluno, idProva])
  @@map("prova_aluno")
}

model Resposta {
  idQuestao    String  @map("id_questao")
  idProvaAluno String  @map("id_prova_aluno")
  resposta     String
  resultado    Boolean

  questao    Questao    @relation(fields: [idQuestao], references: [id])
  provaAluno ProvaAluno @relation(fields: [idProvaAluno], references: [id])

  @@id([idProvaAluno, idQuestao])
  @@map("respostas")
}

model DomainHabilidade {
  value     Int    @id
  descricao String

  questaos Questao[]

  @@map("@habilidades")
}

model DomainCarreira {
  value String @id
  label String @unique

  alunos Aluno[]

  @@map("@carreiras")
}

model DomainAssuntos {
  value String @id
  label String

  questaos Questao[]

  @@map("@assuntos")
}

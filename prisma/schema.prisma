// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  nome           String
  email          String    @unique
  slug           String    @unique
  dataNascimento DateTime? @map("data_nascimento")
  idProfessor    String?   @map("id_professor")
  passwordHash   String    @map("password_hash")
  resetPassword  Boolean   @default(false) @map("reset_password")
  avatarUrl      String?   @map("avatar_url")
  role           Role      @default(ALUNO)

  alunoDesde    DateTime @default(now()) @map("aluno_desde")
  telefone      String?
  carreiraValue String?  @map("carreira_value")

  professor User?           @relation("ProfessorAluno", fields: [idProfessor], references: [id])
  alunos    User[]          @relation("ProfessorAluno")
  Carreira  DomainCarreira? @relation(fields: [carreiraValue], references: [value])
  accounts  Account[]
  sessions  Session[]
  respostas Resposta[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  PROFESSOR
  ALUNO
  EXALUNO
}

model Prova {
  id          String   @id @default(uuid())
  ano         String
  dataCriacao DateTime @default(now()) @map("data_criacao")

  questoes Questao[]

  @@map("provas")
}

model Questao {
  id              String  @id @default(uuid())
  numero          Int
  gabarito        String
  dificuldade     Int
  habilidadeValue Int     @map("habilidade_value")
  assuntoValue    String  @map("assunto_value")
  idProva         String? @map("id_prova")

  prova      Prova?         @relation(fields: [idProva], references: [id])
  habilidade Habilidade     @relation(fields: [habilidadeValue], references: [value])
  assunto    DomainAssuntos @relation(fields: [assuntoValue], references: [value])
  respostas  Resposta[]

  @@map("questoes")
}

model Habilidade {
  value     Int    @id
  descricao String

  questaos Questao[]

  @@map("@habilidades")
}

model Resposta {
  idAluno   String  @map("id_aluno")
  idQuestao String  @map("id_questao")
  resposta  String
  resultado Boolean

  aluno   User    @relation(fields: [idAluno], references: [id])
  questao Questao @relation(fields: [idQuestao], references: [id])

  @@id([idAluno, idQuestao])
  @@map("respostas")
}

model DomainCarreira {
  value String @id
  label String @unique

  alunos User[]

  @@map("@carreiras")
}

model DomainAssuntos {
  value    String    @id
  label    String
  questaos Questao[]

  @@map("@assuntos")
}
